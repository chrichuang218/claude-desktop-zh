# 默认文本统一 LF
* text=auto eol=lf

# Windows 脚本与批处理必须 CRLF
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# 源码统一 LF
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.json text eol=lf
*.rs text eol=lf
*.html text eol=lf
*.md text eol=lf
*.svg text eol=lf

# 二进制资源
*.png binary
*.jpg binary
*.ico binary
*.icns binary
*.exe binary
*.msi binary
